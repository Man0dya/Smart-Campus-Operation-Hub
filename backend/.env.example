# Backend environment variables
SERVER_PORT=8080
MONGODB_URI=mongodb://localhost:27017/smartcampusdb
# Important: include the database name in the URI path (e.g., /smartcampusdb)
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
FRONTEND_URL=http://localhost:5173
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*
APP_UPLOAD_DIR=uploads

# Cloudinary (ticket image attachments)
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
# Optional
CLOUDINARY_TICKET_FOLDER=smart-campus/tickets
